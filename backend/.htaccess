# ebooks.dkituyiacademy.org — Backend .htaccess
# Location: /home/viyykxmm/public_html/backend/.htaccess

# ─── Passenger ───────────────────────────────────────────────────────────────
# Must be at root level, NEVER inside any <IfModule> block
PassengerEnabled on
PassengerAppRoot /home/viyykxmm/ebook
PassengerBaseURI /backend

# ─── Aliases ─────────────────────────────────────────────────────────────────
# NOTE: Alias doesn't work in .htaccess on most cPanel setups
# Using RewriteRule instead for cPanel compatibility

# ─── Security + CORS headers ─────────────────────────────────────────────────
<IfModule mod_headers.c>
    # API CORS — specific origin, credentials allowed
    Header always set Access-Control-Allow-Origin "https://ebooks.dkituyiacademy.org"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-CSRFToken, X-Requested-With, Range"
    Header always set Access-Control-Allow-Credentials "true"
    # Range/Content-Range needed for PDF.js partial loading
    Header always set Access-Control-Expose-Headers "Content-Range, Content-Length, Accept-Ranges"

    # Media files — wildcard origin is fine here (no credentials)
    <FilesMatch "\.(pdf|jpg|jpeg|png|gif|webp|svg)$">
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Expose-Headers "Content-Range, Content-Length, Accept-Ranges"
        # PDFs must display inline, not download, for PDF.js
        Header set Content-Disposition "inline"
        Header set Accept-Ranges "bytes"
    </FilesMatch>

    # Security headers
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ─── Rewrite rules ────────────────────────────────────────────────────────────
RewriteEngine On

# 1. Handle OPTIONS preflight with proper CORS headers
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L,E=HTTP_ORIGIN:%{HTTP:Origin}]

# Set CORS headers for OPTIONS response
Header always set Access-Control-Allow-Origin "https://ebooks.dkituyiacademy.org" env=HTTP_ORIGIN
Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS" env=HTTP_ORIGIN
Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-CSRFToken, X-Requested-With, Range" env=HTTP_ORIGIN
Header always set Access-Control-Allow-Credentials "true" env=HTTP_ORIGIN
Header always set Access-Control-Max-Age "86400" env=HTTP_ORIGIN

# Also set CORS headers unconditionally for API endpoints
<IfModule mod_headers.c>
    <LocationMatch "^/backend/api/">
        Header always set Access-Control-Allow-Origin "https://ebooks.dkituyiacademy.org"
        Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
        Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-CSRFToken, X-Requested-With, Range"
        Header always set Access-Control-Allow-Credentials "true"
        Header always set Access-Control-Expose-Headers "Content-Range, Content-Length, Accept-Ranges"
    </LocationMatch>
</IfModule>

# 2. Route everything under /backend/ to Passenger → Django
#    Django will serve media files via urls.py
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^backend/(.*)$ passenger_wsgi.py [QSA,L]

# ─── MIME types ───────────────────────────────────────────────────────────────
<IfModule mod_mime.c>
    AddType application/pdf      .pdf
    AddType image/jpeg           .jpg .jpeg
    AddType image/png            .png
    AddType image/gif            .gif
    AddType image/webp           .webp
    AddType image/svg+xml        .svg
    AddType application/json     .json
    AddType font/woff2           .woff2
</IfModule>

# ─── Compression ──────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css
    AddOutputFilterByType DEFLATE application/xml application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json
</IfModule>

# ─── Cache control ────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/gif                 "access plus 1 year"
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    # PDFs change more often than static assets
    ExpiresByType application/pdf           "access plus 1 month"
</IfModule>

# ─── Block sensitive files ────────────────────────────────────────────────────
<Files ~ "^\.">
    Require all denied
</Files>

<FilesMatch "\.(env|log|pyc|pyo|py|ini|cfg|conf)$">
    Require all denied
</FilesMatch>

# ─── Error pages ──────────────────────────────────────────────────────────────
ErrorDocument 401 /backend/error-pages/401.html
ErrorDocument 403 /backend/error-pages/403.html
ErrorDocument 404 /backend/error-pages/404.html
ErrorDocument 500 /backend/error-pages/500.html